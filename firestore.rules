rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own user record
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Household members can read/write their household budget
    match /households/{householdCode} {
      // Read & update: only existing members
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Create: allowed only if the creator includes themselves as a member
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
    }
  }
}
